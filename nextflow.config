// nextflow.config
conda.enabled = true

executor {
    name = 'local'
    memory = '12 GB'
    cpus = 6 
}

params {
    raw_dir = "${projectDir}/raw_data"
    outdir  = "${projectDir}/results"
    
    // Default input structures
    wt_pdb         = "${params.raw_dir}/DYRK1B_AZ191_complex.pdb"
    ligand         = "${params.raw_dir}/AZ191.sdf"
    ligand_resname = "QS0"  // residue name of the ligand in the complex PDB
    
    // Docking bounding box — kept for reference only.
    // DOCKING_GNINA now uses --autobox_ligand (same strategy as REDOCK_VALIDATION).
    // These values are no longer passed to any process.
    box_x   = -17.15
    box_y   = -25.29
    box_z   = -5.63
    box_size = 20.0

    // Replicas and reproducibility
    foldx_runs     = 5   // BuildModel replicas per mutant
    seed           = 42  // global seed for GNINA
    exhaustiveness = 16  // GNINA sampling depth (previously hardcoded to 8)
    num_modes      = 9   // number of poses per GNINA run

    // Docking validation
    rmsd_threshold = 2.0  // Å; acceptance criterion for re-docking onto the crystallographic WT

    // Stability vs. binding signal separation
    ddg_stability_threshold  = 0.5  // kcal/mol; FoldX threshold for a relevant stability change
    delta_affinity_threshold = 0.5  // kcal/mol; GNINA threshold for a relevant affinity change
}

process {
    errorStrategy = 'retry'
    maxRetries = 1

    withLabel: 'gpu_intensive' {
        maxForks = 1 // Crucial to prevent VRAM overflow on the RTX 2060
    }
}

// params.seed is propagated to all stochastic processes:
//   - DOCKING_GNINA       (05_docking_gnina.nf)   → --seed ${params.seed}
//   - REDOCK_VALIDATION   (00_validate_docking.nf) → --seed ${params.seed}
// FoldX 4 exposes no seed parameter; its variability is quantified via replicas.

// Nextflow execution reports
report {
    enabled = true
    file    = "${params.outdir}/reports/pipeline_report.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/reports/pipeline_trace.tsv"
}
timeline {
    enabled = true
    file    = "${params.outdir}/reports/pipeline_timeline.html"
}
dag {
    enabled = true
    file    = "${params.outdir}/reports/pipeline_dag.svg"
}