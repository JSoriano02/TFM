// nextflow.config
conda.enabled = true

executor {
    name = 'local'
    memory = '12 GB'
    cpus = 6 
}

params {
    raw_dir = "${projectDir}/raw_data"
    outdir  = "${projectDir}/results"
    
    // Default input structures
    wt_pdb         = "${params.raw_dir}/DYRK1B_AZ191_complex.pdb"
    ligand         = "${params.raw_dir}/AZ191.sdf"
    ligand_resname = "QS0"  // nombre del residuo del ligando en el PDB del complejo
    
    // Docking bounding box (Adjust these to the actual binding site coordinates)
    box_x   = -17.15
    box_y   = -25.29
    box_z   = -5.63
    box_size = 20.0

    // Réplicas y reproducibilidad (Prioridad 1)
    foldx_runs     = 5   // réplicas BuildModel por mutante
    seed           = 42  // semilla global para GNINA
    exhaustiveness = 16  // muestreo GNINA (antes hardcodeado a 8)
    num_modes      = 9   // número de poses por corrida de GNINA

    // Validación de docking (Prioridad 2)
    rmsd_threshold = 2.0  // Å; criterio de éxito del redocking sobre la WT cristalográfica

    // Separación de señales estabilidad vs unión (Prioridad 4)
    ddg_stability_threshold  = 0.5  // kcal/mol; umbral FoldX para cambio relevante en estabilidad
    delta_affinity_threshold = 0.5  // kcal/mol; umbral GNINA para cambio relevante en afinidad
}

process {
    errorStrategy = 'retry'
    maxRetries = 1

    withLabel: 'gpu_intensive' {
        maxForks = 1 // Crucial to prevent VRAM overflow on the RTX 2060
    }
}

// Trazabilidad: params.seed = 42 se propaga a todos los procesos estocásticos:
//   - DOCKING_GNINA        (05_docking_gnina.nf)  → --seed ${params.seed}
//   - REDOCK_VALIDATION    (00_validate_docking.nf) → --seed ${params.seed}
// FoldX 4 no expone parámetro de semilla; la variabilidad se cuantifica con réplicas.

// Reportes de Nextflow (Prioridad 6)
report {
    enabled = true
    file    = "${params.outdir}/reports/pipeline_report.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/reports/pipeline_trace.tsv"
}
timeline {
    enabled = true
    file    = "${params.outdir}/reports/pipeline_timeline.html"
}
dag {
    enabled = true
    file    = "${params.outdir}/reports/pipeline_dag.svg"
}